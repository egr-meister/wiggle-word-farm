{
  "expo": {
    "name": "Wiggle Word Farm",
    "slug": "wiggle-word-farm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3FFE8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3FFE8"
      },
      "package": "com.wigglewordfarm.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": []
    },
    "plugins": [
      "expo-keep-awake",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "enableProguardInReleaseBuilds": false,
            "enableShrinkResourcesInReleaseBuilds": false,
            "extraProguardRules": "-keep class expo.modules.** { *; }\n-keep class com.facebook.react.** { *; }\n-keep class com.facebook.hermes.** { *; }\n-keep class expo.modules.speech.** { *; }\n-keep class com.reactnativecommunity.asyncstorage.** { *; }\n-keep class com.swmansion.** { *; }\n-keep class com.th3rdwave.safeareacontext.** { *; }\n-keepclassmembers class * { @com.facebook.react.bridge.ReactMethod *; }\n-keepclasseswithmembernames class * { native <methods>; }"
          }
        }
      ]
    ]
  }
}
