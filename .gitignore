# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by expo prebuild).
# The android/ and ios/ folders are fully regenerated by `expo prebuild` in CI,
# so they are not committed. ProGuard/R8 rules are configured via
# expo-build-properties (extraProguardRules) in app.json.
/android
/ios

# Metro
.metro-health-check*

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# Keystores and secrets - NEVER commit real keystores
*.keystore
*.jks
*.p12
release.keystore

# Logs
*.log
