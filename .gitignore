# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by expo prebuild).
# The android/ and ios/ folders are regenerated by `expo prebuild`.
# We keep only our committed reference file: android/app/proguard-rules.pro
/android/*
!/android/app/
/android/app/*
!/android/app/proguard-rules.pro
/ios

# Metro
.metro-health-check*

# Debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store

# Keystores and secrets - NEVER commit real keystores
*.keystore
*.jks
*.p12
release.keystore

# Logs
*.log
